rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'isPro', 'freeRecordsCount'])
          && data.uid is string && data.uid.size() <= 128
          && data.email is string && data.email.size() <= 256
          && data.isPro is bool
          && data.freeRecordsCount is int
          && (!data.keys().contains('proExpiresAt') || (data.proExpiresAt is string && data.proExpiresAt.size() <= 64));
      }

      allow list: if isAdmin();
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
        && incoming().uid == request.auth.uid;
      allow update: if (isOwner(userId) || isAdmin()) && isValidId(userId)
        && (
          // Owner update
          (isOwner(userId) 
            && incoming().uid == existing().uid
            && incoming().email == existing().email
            && (
              (incoming().freeRecordsCount is int) ||
              (incoming().isPro is bool) ||
              (incoming().keys().contains('proExpiresAt'))
            )
          ) ||
          // Admin update
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['isPro', 'proExpiresAt']))
        );
    }
    
    // --- Admin Collection (ReadOnly by anyone, write only by existing admin or system) ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    // --- 2. Transactions Collection ---
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.keys().hasAll(['userId', 'type', 'amount', 'category', 'description', 'timestamp'])
          && data.userId == request.auth.uid
          && data.type in ['expense', 'income']
          && data.amount is number && data.amount >= 0
          && data.category is string && data.category.size() <= 128
          && data.description is string && data.description.size() <= 512
          && data.timestamp is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && isValidTransaction(incoming())
        && incoming().userId == existing().userId;
    }

    // --- 3. Goals Collection ---
    match /goals/{goalId} {
      function isValidGoal(data) {
        return data.keys().hasAll(['userId', 'name', 'targetAmount', 'currentAmount', 'month', 'year'])
          && data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 128
          && data.targetAmount is number && data.targetAmount > 0
          && data.currentAmount is number && data.currentAmount >= 0
          && data.month is int && data.month >= 1 && data.month <= 12
          && data.year is int && data.year >= 2024 && data.year <= 2100;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(goalId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(goalId) && isValidGoal(incoming())
        && incoming().keys().size() == 6;
      allow delete: if isSignedIn() && isValidId(goalId) && resource.data.userId == request.auth.uid;
      
      allow update: if isSignedIn() && isValidId(goalId) && resource.data.userId == request.auth.uid
        && isValidGoal(incoming())
        && incoming().userId == existing().userId
        && (
          // Action: Status Update (Progress)
          (incoming().diff(existing()).affectedKeys().hasOnly(['currentAmount'])) ||
          // Action: Edit Goal Details
          (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'targetAmount']))
        );
    }
  }
}
